# evolve.yaml — Generated by evolve init
version: "1.0.0"

targets:
  - pack: "infrastructure"
    root: "."
    weight: 1

provider:
  type: "claude-max"

notifications:
  - type: "stdout"

schedule:
  autonomous: "0 13 * * *"
  inbox_poll_seconds: 300
  meta_agent: "0 13 * * 0"

resources:
  min_free_ram_mb: 1500
  max_disk_usage_pct: 85

circuit_breaker:
  negative_impact_threshold: 3
  window_days: 7
  action: "pause"
  resume: "manual"

retention:
  workspace_days: 14
  git_tag_days: 30
  changelog_archive_days: 90

convergence:
  max_stalls: 3
  max_iterations: 10

validation:
  tier3_min_free_ram_mb: 1500
  sub_invocation_timeout_seconds: 300
  regression_check_count: 20
  regression_lookback_days: 30

challenge:
  approval_floor_pct: 50

meta_agent:
  enabled: false

pipeline:
  phases:
    - "digest"
    - "strategize"
    - "analyze"
    - "challenge"
    - "implement"
    - "validate"
    - "finalize"
    - "metrics"
